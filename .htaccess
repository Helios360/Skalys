# ============================================================
#  Skalys Business School — Configuration Apache (OVH)
# ============================================================

# ===== Sécurité de base =====
Options -Indexes -MultiViews
ServerSignature Off

# ===== Page d'accueil =====
DirectoryIndex home.php index.php

# ===== Encodage par défaut =====
AddDefaultCharset UTF-8

# ============================================================
#  REDIRECTIONS
# ============================================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force https + host canonique en UN seul hop, pour tout host non-canonique
  # (couvre .com, www, ET le hostname technique OVH)
  RewriteCond %{HTTP_HOST} !^skalys-bs\.fr$ [NC,OR]
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://skalys-bs.fr/$1 [R=301,L]

  # 4. home.php / index.php → /
  RewriteCond %{THE_REQUEST} \s/+(?:home|index)\.php[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  # 5. Ancienne forme formation.php?slug=X → /formation/X
  RewriteCond %{THE_REQUEST} \s/+formation\.php\?slug=([a-z0-9-]+)[\s&] [NC]
  RewriteRule ^ /formation/%1? [R=301,L]

  # 6. Rewrite interne propre
  RewriteRule ^formation/([a-z0-9-]+)/?$ formation.php?slug=$1 [L,QSA]

  # 7. Sitemap dynamique
  RewriteRule ^sitemap\.xml$ sitemap.xml.php [L]

  # 8. Blocage dossiers internes
  RewriteRule ^(components|data)(/|$) - [F,L]
</IfModule>

# ============================================================
#  COMPRESSION GZIP
# ============================================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ============================================================
#  CACHE NAVIGATEUR
# ============================================================

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/gif              "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
  ExpiresByType font/woff              "access plus 1 year"
  ExpiresByType application/font-woff  "access plus 1 year"
  ExpiresByType text/css               "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html              "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.php$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================================
#  EN-TÊTES DE SÉCURITÉ
# ============================================================

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options       "nosniff"
  Header always set X-Frame-Options              "SAMEORIGIN"
  Header always set Referrer-Policy              "strict-origin-when-cross-origin"
  Header always set Permissions-Policy           "geolocation=(), microphone=(), camera=(), interest-cohort=()"
  Header always set Strict-Transport-Security    "max-age=31536000; includeSubDomains" env=HTTPS
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https://staticmap.openstreetmap.de https://www.googletagmanager.com https://googleads.g.doubleclick.net https://www.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; connect-src 'self' https://www.googletagmanager.com https://googleads.g.doubleclick.net https://www.google.com; frame-src https://www.google.com https://maps.google.com https://td.doubleclick.net; frame-ancestors 'self'; base-uri 'self'; form-action 'self' mailto:; object-src 'none'"
</IfModule>

# ============================================================
#  PROTECTION DES FICHIERS SENSIBLES
# ============================================================

<FilesMatch "^(\.htaccess|\.user\.ini|\.env|php\.ini)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ============================================================
#  PAGES D'ERREUR
# ============================================================

ErrorDocument 404 /404.php
ErrorDocument 403 /404.php
# Pas d'ErrorDocument 500 : on laisse Apache afficher la vraie page d'erreur
# pour ne pas masquer les incidents serveur en production.
